# ============================================================
# COPIAR ESTE ARCHIVO A  .streamlit/secrets.toml  Y COMPLETAR
# (en Streamlit Cloud se pega en Settings > Secrets, sin el .example)
# NUNCA commitear secrets.toml -- ya esta en .gitignore
# ============================================================

# IDs de las planillas de Google Sheets (Racing Cars)
[sheets]
caja = "ID_DE_LA_PLANILLA_CAJA_RACING_CARS"
inversion = "ID_DE_LA_PLANILLA_INVERSION"
pagos_cobros = "ID_DE_LA_PLANILLA_PAGOS_Y_COBROS"

# Service account de Google Cloud (Racing Cars, NUEVO -- no el de Crosby).
# Pegar TAL CUAL el contenido del JSON descargado de GCP, campo por campo.
[gcp_service_account]
type = "service_account"
project_id = "racing-cars-xxxxxx"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
client_email = "racing-dashboard@racing-cars-xxxxxx.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/racing-dashboard%40racing-cars-xxxxxx.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
